        "z": "85be64247a05e370",
        "name": "json parse",
        "func": "try {\n    // Parse the JSON string into an object\n    let obj = JSON.parse(msg.payload);\n    // Take only the motion value and convert it to text\n    msg.payload = String(obj.motion); // \"true\" or \"false\"\n} catch (err) {\n    // If parsing fails, just leave it as a string\n    msg.payload = String(msg.payload);\n}\n\nreturn msg;",

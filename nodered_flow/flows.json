    {
        "id": "c95342ef00fc4430",
        "type": "function",
        "z": "85be64247a05e370",
        "name": "function 1",
        "func": "// Get motion value from incoming message\nvar motion = msg.payload.motion;\n\n// Convert to numeric for logging/chart (1 = motion detected, 0 = no motion)\nvar motionValue = motion ? 1 : 0;\n\n// Add timestamp for logging\nvar timestamp = new Date().toISOString();\n\n// Prepare CSV line for logging (or append to sensor CSV)\nmsg.payload = `${timestamp},${motionValue}`;\n\n// Optionally, forward a simplified payload for dashboard charts\nmsg.motionValue = motionValue;\nmsg.timestamp = timestamp;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
        "y": 520,
